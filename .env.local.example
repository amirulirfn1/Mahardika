# =============================================================================
# 🚀 Mahardika Platform Environment Variables Template
# =============================================================================
# Copy this file to .env.local and fill in your actual values
# 
# Brand Colors: Navy #0D1B2A • Gold #F4B400
# Repository: https://github.com/amirulirfn1/Mahardika.git
# =============================================================================

# -----------------------------------------------------------------------------
# 🔑 API Configuration
# -----------------------------------------------------------------------------

# DeepSeek AI API Configuration
# Get your API key from: https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# -----------------------------------------------------------------------------
# 🎨 Mahardika Brand Configuration
# -----------------------------------------------------------------------------

# Brand Colors (for dynamic theming)
NEXT_PUBLIC_BRAND_NAVY=#0D1B2A
NEXT_PUBLIC_BRAND_GOLD=#F4B400

# Application Configuration
NEXT_PUBLIC_APP_NAME=Mahardika Platform
NEXT_PUBLIC_APP_VERSION=1.0.0

# -----------------------------------------------------------------------------
# 🏗️ Next.js Configuration
# -----------------------------------------------------------------------------

# Next.js Environment
NODE_ENV=development

# NextAuth Configuration (if implementing authentication)
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars-long
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# 🗄️ Database Configuration
# -----------------------------------------------------------------------------

# Supabase Configuration
# Get these from your Supabase dashboard: https://app.supabase.com
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Public Supabase Configuration (exposed to client)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Database URL (alternative/additional database)
# DATABASE_URL=postgresql://username:password@localhost:5432/mahardika_db
# DATABASE_PASSWORD=your_secure_database_password

# -----------------------------------------------------------------------------
# 🎛️ Feature Flags
# -----------------------------------------------------------------------------

# Enable/disable features
NEXT_PUBLIC_ENABLE_AI_CHAT=true
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SECURITY_STATUS=true
DEBUG_MODE=false

# -----------------------------------------------------------------------------
# 💳 External Services (Optional)
# -----------------------------------------------------------------------------

# Stripe Configuration (for payments)
# STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Email Service Configuration
# SENDGRID_API_KEY=SG.your_sendgrid_api_key
# SENDGRID_FROM_EMAIL=noreply@mahardika.com

# File Upload Configuration
# UPLOADCARE_PUBLIC_KEY=your_uploadcare_public_key
# UPLOADCARE_SECRET_KEY=your_uploadcare_secret_key

# -----------------------------------------------------------------------------
# 📊 Analytics & Monitoring (Optional)
# -----------------------------------------------------------------------------

# Google Analytics
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
# GOOGLE_ANALYTICS_MEASUREMENT_ID=G-XXXXXXXXX

# Mixpanel Analytics
# NEXT_PUBLIC_MIXPANEL_TOKEN=your_mixpanel_token

# Sentry Error Monitoring
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_AUTH_TOKEN=your_sentry_auth_token

# Vercel Analytics (if using Vercel)
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=your_vercel_analytics_id

# -----------------------------------------------------------------------------
# ☁️ Cloud Services (Optional)
# -----------------------------------------------------------------------------

# AWS Configuration
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# AWS_S3_BUCKET_NAME=mahardika-uploads

# Cloudinary Configuration
# CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
# CLOUDINARY_API_KEY=your_cloudinary_api_key
# CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# -----------------------------------------------------------------------------
# 🔒 Security Configuration
# -----------------------------------------------------------------------------

# CORS Configuration
# CORS_ORIGIN=http://localhost:3000

# Rate Limiting
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_WINDOW_MS=900000

# Content Security Policy
# CSP_REPORT_URI=https://your-csp-report-endpoint.com/report

# -----------------------------------------------------------------------------
# 🛠️ Development Tools
# -----------------------------------------------------------------------------

# Prisma Configuration
# PRISMA_GENERATE_DATAPROXY=false
# PRISMA_HIDE_UPDATE_MESSAGE=true

# Storybook Configuration (if using Storybook)
# STORYBOOK_THEME=mahardika

# -----------------------------------------------------------------------------
# 🎯 Environment-Specific Overrides
# -----------------------------------------------------------------------------

# Development-specific variables
# DEV_API_BASE_URL=http://localhost:3001/api
# DEV_ENABLE_MOCK_DATA=true

# Staging-specific variables
# STAGING_API_BASE_URL=https://api-staging.mahardika.com
# STAGING_ENABLE_DEBUG=true

# Production-specific variables
# PROD_API_BASE_URL=https://api.mahardika.com
# PROD_ENABLE_COMPRESSION=true

# =============================================================================
# 📝 Usage Instructions
# =============================================================================
#
# 1. Copy this file to .env.local:
#    cp .env.local.example .env.local
#
# 2. Fill in your actual values (never commit .env.local to git)
#
# 3. Restart your development server:
#    pnpm run dev
#
# 4. Visit your application:
#    http://localhost:3000
#
# 🔗 Resources:
# • Supabase Dashboard: https://app.supabase.com
# • DeepSeek API: https://platform.deepseek.com
# • Mahardika Repository: https://github.com/amirulirfn1/Mahardika.git
#
# 🎨 Mahardika Brand:
# • Navy: #0D1B2A (Primary)
# • Gold: #F4B400 (Accent)
#
# =============================================================================