{
  "name": "@mahardika/web",
  "version": "1.0.0",
  "private": true,
  "description": "Mahardika Web Application - Showcase for UI components",
  "scripts": {
    "prebuild": "node copy-ui-package.js",
    "predev": "node setup-database.js",
    "build": "next build",
    "dev": "next dev",
    "lint": "next lint",
    "lint:fix": "next lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "next start",
    "type-check": "tsc --noEmit",
    "postinstall": "prisma generate && node copy-ui-package.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@mahardika/ui": "file:./local-ui",
    "@prisma/client": "^5.19.1",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.50.0",
    "bcryptjs": "^2.4.3",
    "bootstrap": "5.3.3",
    "next": "^15.3.4",
    "pdfkit": "^0.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@sentry/nextjs": "^9.32.0",
    "@tanstack/react-query": "^5.81.2",
    "@tanstack/react-table": "^8.10.0",
    "axios": "^1.6.8",
    "lucide-react": "^0.523.0",
    "react-chartjs-2": "^6.7.1",
    "chart.js": "^4.4.1",
    "react-bootstrap": "^2.10.2",
    "i18next": "^23.11.5",
    "react-i18next": "^14.0.0",
    "i18next-browser-languagedetector": "^7.0.1"
  },
  "devDependencies": {
    "@edge-runtime/jest-environment": "^3.0.4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.19.0",
    "@types/pdfkit": "^0.13.9",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.4.2",
    "prisma": "^5.19.1",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3"
  },
  "keywords": [
    "mahardika",
    "web",
    "nextjs",
    "showcase"
  ],
  "author": "Mahardika Team",
  "engines": {
    "node": ">=22.15.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
