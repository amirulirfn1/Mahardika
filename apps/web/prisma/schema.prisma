// Mahardika Platform - Multi-tenant SaaS Database Schema
// Brand Colors: Navy #0D1B2A, Gold #F4B400

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// CORE AGENCY MANAGEMENT (Multi-tenant)
// =============================================================================

model Agency {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  logo_url    String?  @db.VarChar(500)
  website     String?  @db.VarChar(255)
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(50)
  address     String?  @db.Text
  city        String?  @db.VarChar(100)
  state       String?  @db.VarChar(100)
  country     String?  @db.VarChar(100)
  postal_code String?  @db.VarChar(20)
  timezone    String   @default("UTC") @db.VarChar(50)
  
  // Branding
  brand_color_primary   String? @default("#0D1B2A") @db.VarChar(7)
  brand_color_secondary String? @default("#F4B400") @db.VarChar(7)
  
  // Subscription & Billing
  plan_type        String   @default("starter") @db.VarChar(50)
  billing_email    String?  @db.VarChar(255)
  subscription_id  String?  @db.VarChar(255)
  
  // Metadata
  settings Json?
  metadata Json?
  
  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
  
  // Relations
  users      User[]
  customers  Customer[]
  policies   Policy[]
  reviews    Review[]
  
  @@map("agencies")
}

// =============================================================================
// USER MANAGEMENT
// =============================================================================

model User {
  id         String  @id @default(uuid()) @db.Uuid
  agency_id  String  @db.Uuid
  email      String  @unique @db.VarChar(255)
  name       String  @db.VarChar(255)
  avatar_url String? @db.VarChar(500)
  role       String  @default("member") @db.VarChar(50)
  
  // Authentication
  password_hash String?  @db.VarChar(255)
  email_verified Boolean @default(false)
  
  // Permissions
  permissions Json?
  
  // Profile
  phone      String? @db.VarChar(50)
  department String? @db.VarChar(100)
  title      String? @db.VarChar(100)
  
  // Timestamps
  last_login_at DateTime? @db.Timestamptz(6)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @updatedAt @db.Timestamptz(6)
  
  // Relations
  agency Agency @relation(fields: [agency_id], references: [id], onDelete: Cascade)
  
  @@map("users")
  @@index([agency_id])
  @@index([email])
}

// =============================================================================
// CUSTOMER MANAGEMENT
// =============================================================================

model Customer {
  id        String  @id @default(uuid()) @db.Uuid
  agency_id String  @db.Uuid
  email     String  @db.VarChar(255)
  name      String  @db.VarChar(255)
  phone     String? @db.VarChar(50)
  
  // Address
  address     String? @db.Text
  city        String? @db.VarChar(100)
  state       String? @db.VarChar(100)
  country     String? @db.VarChar(100)
  postal_code String? @db.VarChar(20)
  
  // Demographics
  date_of_birth DateTime? @db.Date
  gender        String?   @db.VarChar(20)
  occupation    String?   @db.VarChar(100)
  
  // Loyalty System
  loyalty_points Int    @default(0)
  tier          String @default("bronze") @db.VarChar(50) // bronze, silver, gold, platinum
  
  // Customer Status
  status       String @default("active") @db.VarChar(50)
  notes        String? @db.Text
  
  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
  
  // Relations
  agency   Agency   @relation(fields: [agency_id], references: [id], onDelete: Cascade)
  policies Policy[]
  reviews  Review[]
  
  @@map("customers")
  @@index([agency_id])
  @@index([email])
  @@index([loyalty_points])
  @@index([tier])
}

// =============================================================================
// POLICY MANAGEMENT
// =============================================================================

enum PolicyStatus {
  DRAFT
  ACTIVE
  EXPIRED
}

model Policy {
  id          String       @id @default(uuid()) @db.Uuid
  agency_id   String       @db.Uuid
  customer_id String       @db.Uuid
  
  // Policy Details
  policy_number String @unique @db.VarChar(100)
  policy_type   String @db.VarChar(100)
  product_name  String @db.VarChar(255)
  
  // Status & Dates
  status     PolicyStatus @default(DRAFT)
  start_date DateTime     @db.Date
  end_date   DateTime     @db.Date
  
  // Financial
  premium_amount    Decimal @db.Decimal(10, 2)
  coverage_amount   Decimal @db.Decimal(15, 2)
  deductible_amount Decimal @default(0) @db.Decimal(10, 2)
  
  // Policy Terms
  terms_conditions String? @db.Text
  benefits         Json?
  exclusions       Json?
  
  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
  
  // Relations
  agency   Agency   @relation(fields: [agency_id], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  
  @@map("policies")
  @@index([agency_id])
  @@index([customer_id])
  @@index([policy_number])
  @@index([status])
}

// =============================================================================
// REVIEW SYSTEM
// =============================================================================

model Review {
  id          String  @id @default(uuid()) @db.Uuid
  agency_id   String  @db.Uuid
  customer_id String  @db.Uuid
  
  // Review Details
  rating      Int     @db.SmallInt // 1-5 scale
  title       String? @db.VarChar(255)
  content     String? @db.Text
  
  // Review Metadata
  service_type String? @db.VarChar(100)
  is_verified  Boolean @default(false)
  is_featured  Boolean @default(false)
  
  // Response
  response         String?   @db.Text
  response_date    DateTime? @db.Timestamptz(6)
  
  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
  
  // Relations
  agency   Agency   @relation(fields: [agency_id], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customer_id], references: [id], onDelete: Cascade)
  
  @@map("reviews")
  @@index([agency_id, rating]) // Composite index for performance
  @@index([customer_id])
  @@index([is_featured])
}

// =============================================================================
// ANALYTICS & REPORTING
// =============================================================================

model Analytics {
  id        String   @id @default(uuid()) @db.Uuid
  agency_id String   @db.Uuid
  
  // Metrics
  metric_name  String @db.VarChar(100)
  metric_value Decimal @db.Decimal(15, 2)
  metric_type  String @db.VarChar(50) // count, sum, average, etc.
  
  // Dimensions
  dimension Json?
  
  // Time
  recorded_at DateTime @db.Timestamptz(6)
  period_type String   @db.VarChar(20) // daily, weekly, monthly, yearly
  
  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  
  @@map("analytics")
  @@index([agency_id])
  @@index([metric_name])
  @@index([recorded_at])
}

// =============================================================================
// AUDIT LOGS
// =============================================================================

model AuditLog {
  id        String @id @default(uuid()) @db.Uuid
  agency_id String @db.Uuid
  
  // Action Details
  action      String @db.VarChar(100)
  resource    String @db.VarChar(100)
  resource_id String @db.Uuid
  
  // User Context
  user_id    String? @db.Uuid
  user_email String? @db.VarChar(255)
  user_role  String? @db.VarChar(50)
  
  // Change Details
  old_values Json?
  new_values Json?
  
  // Request Context
  ip_address String? @db.VarChar(45)
  user_agent String? @db.Text
  
  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  
  @@map("audit_logs")
  @@index([agency_id])
  @@index([resource, resource_id])
  @@index([user_id])
  @@index([created_at])
}

// =============================================================================
// SYSTEM CONFIGURATION
// =============================================================================

model SystemConfig {
  id    String @id @default(uuid()) @db.Uuid
  key   String @unique @db.VarChar(100)
  value Json
  
  // Metadata
  description String? @db.Text
  is_public   Boolean @default(false)
  
  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
  
  @@map("system_config")
}

// =============================================================================
// NOTIFICATIONS
// =============================================================================

model Notification {
  id        String  @id @default(uuid()) @db.Uuid
  agency_id String  @db.Uuid
  user_id   String? @db.Uuid
  
  // Notification Details
  title   String @db.VarChar(255)
  content String @db.Text
  type    String @db.VarChar(50)
  
  // Status
  is_read   Boolean @default(false)
  is_sent   Boolean @default(false)
  
  // Delivery
  delivery_method String?   @db.VarChar(50) // email, sms, push, in_app
  sent_at         DateTime? @db.Timestamptz(6)
  read_at         DateTime? @db.Timestamptz(6)
  
  // Metadata
  metadata Json?
  
  // Timestamps
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)
  
  @@map("notifications")
  @@index([agency_id])
  @@index([user_id])
  @@index([is_read])
} 