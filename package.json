{
  "name": "mah-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Mahardika Platform - Complete monorepo with UI library and applications",
  "scripts": {
    "build": "pnpm run --filter='./packages/*' build",
    "test": "pnpm run --filter='./packages/*' test",
    "dev": "pnpm run --filter='@mahardika/web' dev",
    "lint": "pnpm run --filter='./packages/*' lint",
    "clean": "pnpm run --filter='./packages/*' clean",
    "bootstrap": "scripts/bootstrap.bat",
    "bootstrap:bash": "bash scripts/bootstrap.sh",
    "security:check": "node scripts/security-check.js",
    "security:scan": "git log --all -p | grep -i 'api_key\\|secret\\|password\\|token' || echo 'No secrets found'",
    "env:template": "cp .env.local.example .env.local",
    "pre-commit": "pnpm run security:check && pnpm run build && pnpm run test"
  },
  "keywords": ["mahardika", "monorepo", "ui", "react", "nextjs"],
  "author": "Mahardika Team",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  }
} 