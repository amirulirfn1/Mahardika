            </table>
          </div>
        </div>
      </div>

      <div className="col-lg-4">
        {/* Recent Activity */}
        <div className="card">
          <div className="filter">
            <a className="icon" href="#" data-bs-toggle="dropdown"><i className="bi bi-three-dots"></i></a>
            <ul className="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
