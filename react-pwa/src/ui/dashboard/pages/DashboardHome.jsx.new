                  </div>}

                  {dayActivity.activities.map((activity, actIndex) => (
                    <div className="activity-item d-flex" key={actIndex}>
                      <div className="activite-label">{activity.time}</div>
                      <i className={`bi bi-circle-fill activity-badge ${activity.color} align-self-start`}></i>
                      <div className="activity-content">
                        <strong>{activity.title}</strong> - {activity.text}
                      </div>
                    </div>
                  ))}
                </React.Fragment>
              ))}
            </div>
          </div>
        </div>

        {/* Department Budget Report */}
        <div className="card">
          <div className="filter">
            <a className="icon" href="#" data-bs-toggle="dropdown"><i className="bi bi-three-dots"></i></a>
            <ul className="dropdown-menu dropdown-menu-end dropdown-menu-arrow">
              <li className="dropdown-header text-start">
                <h6>Filter</h6>
              </li>
              <li><a className="dropdown-item" href="#">Today</a></li>
              <li><a className="dropdown-item" href="#">This Month</a></li>
              <li><a className="dropdown-item" href="#">This Year</a></li>
            </ul>
          </div>

          <div className="card-body pb-0">
            <h5 className="card-title">Department Budget Report <span>| This Month</span></h5>

            <div id="budgetChart" className="echart"></div>

            {/* The chart is initialized by NiceAdmin's main.js */}
          </div>
        </div>

        {/* Quick Actions */}
        <div className="card">
          <div className="card-body">
            <h5 className="card-title">Quick Actions</h5>

            <div className="quick-actions">
