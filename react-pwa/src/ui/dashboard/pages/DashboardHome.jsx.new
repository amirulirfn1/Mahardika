      text: 'compared to last month'
    },
    { 
      title: 'TODAY\'S APPOINTMENTS', 
      value: '42', 
      icon: 'bi bi-calendar-check',
      iconClass: 'revenue-icon',
      percentChange: 8,
      isIncrease: true,
      text: 'compared to yesterday'
    },
    { 
      title: 'ACTIVE TREATMENTS', 
      value: '67', 
      icon: 'bi bi-activity',
      iconClass: 'customers-icon',
