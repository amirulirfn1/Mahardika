{
  "version": 2,
  "builds": [
    {
      "src": "apps/web/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/web/$1"
    }
  ],
  "env": {
    "DEEPSEEK_API_KEY": "@deepseek-api-key"
  },
  "functions": {
    "apps/web/src/app/api/chat/route.ts": {
      "maxDuration": 30
    },
    "apps/web/src/app/api/cron/updateClamSig.ts": {
      "maxDuration": 300
    },
    "apps/web/src/app/api/compressUpload/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/updateClamSig",
      "schedule": "0 2 * * *"
    }
  ],
  "regions": ["iad1"],
  "installCommand": "pnpm install",
  "buildCommand": "cd apps/web && pnpm build",
  "outputDirectory": "apps/web/.next"
}
